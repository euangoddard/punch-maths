---
import { Font } from "astro:assets";
import App from "../App";
import "../styles/index.css";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"
    />
    <meta
      name="description"
      content="Punch Maths — physical maths game using your webcam"
    />
    <meta name="theme-color" content="#1e1b4b" />
    <title>Punch Maths</title>
    <link rel="icon" type="image/svg+xml" href="/icon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Punch Maths" />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Punch Maths" />
    <meta property="og:description" content="Physical maths game using your webcam" />
    <meta property="og:url" content="https://punch-maths.euans.space/" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Punch Maths" />
    <meta name="twitter:description" content="Physical maths game using your webcam" />
    <Font cssVariable="--font-display" preload />
    <Font cssVariable="--font-body" preload />
  </head>
  <body>
    <App client:only="preact" />
  </body>
</html>
